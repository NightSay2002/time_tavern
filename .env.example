# 複製此檔案為 .env，然後只填寫你需要啟用的設定。

# 伺服器
PORT=3234

# Discord Bot
# 不填 DISCORD_BOT_TOKEN 時，只會啟動本地網頁管理端，不會登入 Discord。
DISCORD_BOT_TOKEN=
# 選填。若無法從 Bot Token 解出 Client ID，會用這個產生 Discord 邀請連結。
DISCORD_CLIENT_ID=
# Discord 文字指令前綴，例如：!ai 你好
COMMAND_PREFIX=!ai
# Discord .txt 附件大小上限，單位是 bytes。預設：1048576（1 MB）。
DISCORD_TEXT_ATTACHMENT_MAX_BYTES=1048576

# DeepSeek API
DEEPSEEK_API_KEY=
# API 請求逾時時間，單位是毫秒。預設：600000（10 分鐘）。
DEEPSEEK_REQUEST_TIMEOUT_MS=600000
# 選填。覆蓋輸出 token 上限；主聊天／壓縮呼叫預設 32000，仍會受模型上限限制。
# DEEPSEEK_MAX_TOKENS=32000

# 選填。上下文壓縮可以使用另一組 DeepSeek API key。
# 建議使用：
DEEPSEEK_API_KEY2=

# 回覆行為
# 最終回覆的最少可見字數；太短時會觸發提示或補救流程。
AI_MIN_REPLY_CHARS=600
