# Server
PORT=3234

# Discord / DeepSeek
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DISCORD_GUILD_ID=
COMMAND_PREFIX=!ai
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek API request timeout in milliseconds. Default in code is 600000 (600 seconds).
DEEPSEEK_REQUEST_TIMEOUT_MS=600000
# 固定只使用 reasoner_history：第一輪先做狀態預處理，第二輪只用最近對話脈絡輸出正文
DEEPSEEK_CALL_MODE=reasoner_history
# Optional override for reasoner_history/state_rewrite output tokens
# If you still see finish_reason:length, increase this value first.
DEEPSEEK_MAX_TOKENS=64000
# Optional override for deepseek-chat when state prep 測試模式啟用時使用。
# 未設定時會自動封頂到 deepseek-chat 可接受的最大值（目前程式內限制為 8192）。
DEEPSEEK_CHAT_MAX_TOKENS=8192
# How many recent dialogue rounds to send in each main chat call
DEEPSEEK_DIALOGUE_CONTEXT_ROUNDS=10
# Minimum visible characters required for final role reply; two-call flow will only warn if too short
AI_MIN_REPLY_CHARS=600
# Prompt rule only; this guides style/length but does not change the API token ceiling.
AI_REPLY_LENGTH_RULE="針對每次對話的輸出需要多於600字,但不超過1000字,每段约60-80字.具體字數由他決定"

# AI prompts
# 長篇分段 prompt 建議改放文字檔，較好查看與編輯；若有設定 *_FILE，會優先讀檔案內容。
AI_REASONER_HISTORY_SYSTEM_PROMPT_FILE=./prompts/reasoner-history-system-prompt.txt
AI_STATE_PREP_SYSTEM_PROMPT_FILE=./prompts/state-prep-system-prompt.txt
# 若你仍想直接放在 env，也可以改用下面兩個變數並使用 \n 換行：
# AI_REASONER_HISTORY_SYSTEM_PROMPT="..."
# AI_STATE_PREP_SYSTEM_PROMPT="..."
