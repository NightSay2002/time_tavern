# 複製此檔案為 .env，然後只填寫你需要啟用的設定。

# 伺服器
PORT=3234

# Discord Bot
# 不填 DISCORD_BOT_TOKEN 時，只會啟動本地網頁管理端，不會登入 Discord。
DISCORD_BOT_TOKEN=
# 選填。若無法從 Bot Token 解出 Client ID，會用這個產生 Discord 邀請連結。
DISCORD_CLIENT_ID=
# Discord 文字指令前綴，例如：!ai 你好
COMMAND_PREFIX=!ai
# Discord .txt 附件大小上限，單位是 bytes。預設：1048576（1 MB）。
DISCORD_TEXT_ATTACHMENT_MAX_BYTES=1048576

# 對話API
# 支援 OpenAI-compatible Chat Completions API。
# 供應商可用：deepseek / openai / gemini / custom。
CHAT_API_PROVIDER=deepseek
# 可填 DeepSeek、OpenAI 或 Gemini API key。
CHAT_API_KEY=
# 留空會依 CHAT_API_PROVIDER 使用預設 Base URL。
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com/v1
# Gemini: https://generativelanguage.googleapis.com/v1beta/openai
CHAT_API_BASE_URL=
# API輸出模型，例如 deepseek-reasoner、gpt-4.1、gemini-2.5-flash。
CHAT_API_MODEL=deepseek-reasoner
# API 請求逾時時間，單位是毫秒。預設：600000（10 分鐘）。
CHAT_API_REQUEST_TIMEOUT_MS=600000
# 選填。覆蓋輸出 token 上限；主聊天／壓縮呼叫預設 32000，仍會受模型上限限制。
# CHAT_API_MAX_TOKENS=32000
# 大多數 OpenAI-compatible API 使用 max_tokens；部分 OpenAI 新模型可改用 max_completion_tokens。
CHAT_API_MAX_TOKENS_PARAM=max_tokens
# 選填。一般對話留空時使用 0.5。
# CHAT_API_TEMPERATURE=0.5

# 選填。大模型內容處理 key，依啟用的大模型順序使用；Key 不足時沿用最後一把。
CHAT_API_KEY2=
# CHAT_API_KEY3=
# CHAT_API_KEY4=

# 回覆行為
# 最終回覆的最少可見字數；太短時會觸發提示或補救流程。
AI_MIN_REPLY_CHARS=600
